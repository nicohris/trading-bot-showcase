# =============================================================================
# TRADING BOT — Configuration Environment
# Copier ce fichier en .env et remplir les valeurs réelles
# Ne JAMAIS committer .env dans git
# =============================================================================

# --- Mode d'exécution ---
# Options: backtest | paper | live
TRADING_MODE=paper

# --- Binance API ---
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here
# Utiliser le testnet Binance pour paper trading si souhaité
BINANCE_TESTNET=false

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json  # json | console

# --- Storage ---
DATABASE_URL=sqlite:///./data/trading_bot.db

# --- Bot général ---
# Intervalle de polling en secondes pour le runtime live
POLLING_INTERVAL_SECONDS=60
